{
  "name": "seekforge",
  "version": "0.7.0",
  "description": "A local-first coding agent powered by DeepSeek.",
  "license": "MIT",
  "author": "eilyeee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eilyeee/seekforge.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/eilyeee/seekforge#readme",
  "keywords": [
    "coding-agent",
    "agent",
    "deepseek",
    "cli",
    "ai"
  ],
  "type": "module",
  "bin": {
    "seekforge": "bin/seekforge.js",
    "seekforge-tui": "bin/seekforge-tui.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/__tests__/helpers.test.ts && tsx src/__tests__/stream-input.test.ts && tsx src/__tests__/output-style.test.ts && tsx src/__tests__/config.test.ts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@seekforge/core": "workspace:*",
    "@seekforge/server": "workspace:*",
    "@seekforge/shared": "workspace:*",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
