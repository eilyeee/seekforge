{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SeekForge",
  "version": "0.7.0",
  "identifier": "com.seekforge.app",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "pnpm --filter @seekforge/desktop build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "externalBin": ["binaries/seekforge-server"],
    "resources": {
      "../dist": "web"
    },
    "category": "DeveloperTool",
    "publisher": "SeekForge",
    "copyright": "© 2026 SeekForge contributors",
    "shortDescription": "Local-first DeepSeek coding agent",
    "longDescription": "SeekForge is a local-first coding agent powered by DeepSeek: chat, sessions, diffs, skills, sub-agents, memory and self-evolution in one desktop workbench.",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "windowSize": { "width": 660, "height": 420 },
        "appPosition": { "x": 180, "y": 180 },
        "applicationFolderPosition": { "x": 480, "y": 180 }
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/eilyeee/seekforge/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IHVwZGF0ZXIgZGlzYWJsZWQ="
    }
  }
}
